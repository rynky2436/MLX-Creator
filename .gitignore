# Model weights & generated media — huge, downloaded on demand, not source.
# Anchored to repo root so they don't match vendored code dirs named the same
# (e.g. vendor/mflux/src/mflux/models/).
/models/
/outputs/

# Python environment
.venv/
__pycache__/
*.pyc
*.pyo

# Vendored third-party VCS metadata (source is kept, .git is not)
vendor/**/.git/

# misc
.DS_Store
*.log
settings.json

# packaging build artifacts (regenerable)
packaging/build/
packaging/dmg_stage/
packaging/*.dmg
